{
	"name": "@user6m/home-pruner",
	"version": "1.0.2",
	"description": "An interactive CLI tool to delete local git branches.",
	"author": "user6m",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/user6m/home-pruner.git"
	},
	"keywords": [
		"git",
		"cli",
		"interactive",
		"branch",
		"prune",
		"delete"
	],
	"bugs": {
		"url": "https://github.com/user6m/home-pruner/issues"
	},
	"homepage": "https://github.com/user6m/home-pruner#readme",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"bin": {
		"home-pruner": "dist/main.js"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "esbuild src/main.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/main.js --banner:js=\"#!/usr/bin/env node\"",
		"dev": "pnpm run build -- --sourcemap=inline",
		"lint": "biome lint --write",
		"lint:ci": "biome ci",
		"format:ci": "biome format",
		"check": "biome check --write",
		"prepublishOnly": "pnpm run typecheck && pnpm run build",
		"test:create-unmerged": "./scripts/create-unmerged-branch.sh",
		"test": "vitest run",
		"release": "release-it"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/node": "^25.9.3",
		"esbuild": "^0.28.1",
		"globals": "^17.6.0",
		"release-it": "^20.2.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.8"
	},
	"packageManager": "pnpm@10.29.3"
}
